+/* iwish diagnostic: report the X virtual-screen size (SdlTkX.screen->width/height),
+ * distinct from `sdltk size` which reports the SDL window size. */
+static int
+ScreensizeObjCmd(ClientData clientData, Tcl_Interp *interp,
+		 int objc, Tcl_Obj *const objv[])
+{
+    char buffer[128];
+    sprintf(buffer, "%d %d",
+	    SdlTkX.screen ? SdlTkX.screen->width : -1,
+	    SdlTkX.screen ? SdlTkX.screen->height : -1);
+    Tcl_SetResult(interp, buffer, TCL_VOLATILE);
+    return TCL_OK;
+}
