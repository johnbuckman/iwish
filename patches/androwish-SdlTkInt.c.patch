+/*
+ *----------------------------------------------------------------------
+ *
+ * BorgtoastObjCmd --
+ *
+ *	sdltk borgtoast WINDOW MS
+ *
+ *	Capture the pixels of WINDOW (an already-rendered, offscreen Tk
+ *	canvas holding a rounded toast on a pure-magenta background) and
+ *	hand them to the SDL present layer so they are composited on top of
+ *	every frame -- always foreground -- for MS milliseconds.  The
+ *	magenta background is chroma-keyed to full transparency so only the
+ *	rounded toast shows.  See SdlTkGfxDrawBorgToast() in SdlTkGfx.c.
+ *
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgtoastObjCmd(ClientData clientData, Tcl_Interp *interp,
+		int objc, Tcl_Obj *const objv[])
+{
+    Tk_Window tkwin = (Tk_Window) clientData;
+    Tk_Window toast;
+    int ms, w, h, i, n;
+    _Window *_w;
+    Display *display;
+    XImage *img;
+    SDL_Surface *src, *conv;
+    Uint32 *px;
+    void *packed = NULL;
+    int ret = TCL_OK;
+
+    if (objc != 3) {
+	Tcl_WrongNumArgs(interp, 1, objv, "window ms");
+	return TCL_ERROR;
+    }
+    if (TkGetWindowFromObj(interp, tkwin, objv[1], &toast) != TCL_OK) {
+	return TCL_ERROR;
+    }
+    if (Tcl_GetIntFromObj(interp, objv[2], &ms) != TCL_OK) {
+	return TCL_ERROR;
+    }
+    Tk_MakeWindowExist(toast);
+    w = Tk_Width(toast);
+    h = Tk_Height(toast);
+    if ((w <= 0) || (h <= 0)) {
+	Tcl_SetObjResult(interp,
+			 Tcl_NewStringObj("toast window has no size", -1));
+	return TCL_ERROR;
+    }
+    display = Tk_Display(toast);
+    _w = (_Window *) ((TkWindow *) toast)->window;
+
+    /* XGetImage takes the xlib lock itself; SdlTkLock is non-recursive, so we
+     * must NOT be holding it here or we deadlock. */
+    img = XGetImage(display, (Drawable) _w, 0, 0,
+		    (unsigned) w, (unsigned) h, AllPlanes, ZPixmap);
+    if (img == NULL) {
+	Tcl_SetObjResult(interp,
+			 Tcl_NewStringObj("toast capture failed", -1));
+	return TCL_ERROR;
+    }
+
+    /* Wrap the captured pixels (root-surface format) and convert to a
+     * known ARGB8888 layout we can hand to the renderer. */
+    src = SDL_CreateRGBSurfaceFrom(img->data, w, h,
+	    SdlTkX.sdlsurf->format->BitsPerPixel, img->bytes_per_line,
+	    SdlTkX.sdlsurf->format->Rmask, SdlTkX.sdlsurf->format->Gmask,
+	    SdlTkX.sdlsurf->format->Bmask, SdlTkX.sdlsurf->format->Amask);
+    if (src == NULL) {
+	XDestroyImage(img);
+	Tcl_SetObjResult(interp,
+			 Tcl_NewStringObj("toast surface failed", -1));
+	return TCL_ERROR;
+    }
+    conv = SDL_ConvertSurfaceFormat(src, SDL_PIXELFORMAT_ARGB8888, 0);
+    SDL_FreeSurface(src);
+    XDestroyImage(img);
+    if (conv == NULL) {
+	Tcl_SetObjResult(interp,
+			 Tcl_NewStringObj("toast convert failed", -1));
+	return TCL_ERROR;
+    }
+
+    /* Chroma-key: the magenta canvas background -> transparent; everything
+     * else -> opaque.  Anti-aliased edges (black/magenta blends) keep their
+     * colour and stay opaque, giving a soft edge with no magenta halo. */
+    px = (Uint32 *) conv->pixels;
+    n = (conv->pitch / 4) * h;
+    for (i = 0; i < n; i++) {
+	Uint32 p = px[i];
+	int r = (p >> 16) & 0xFF;
+	int g = (p >>  8) & 0xFF;
+	int b = (p      ) & 0xFF;
+
+	if ((r > 180) && (g < 80) && (b > 180)) {
+	    px[i] = 0;				/* transparent */
+	} else {
+	    px[i] = 0xFF000000u | (p & 0x00FFFFFFu); /* opaque */
+	}
+    }
+
+    /* SdlTkBorgToastSet wants tightly packed w*4 rows. */
+    if (conv->pitch != w * 4) {
+	packed = ckalloc((size_t) w * h * 4);
+	for (i = 0; i < h; i++) {
+	    memcpy((char *) packed + (size_t) i * w * 4,
+		   (char *) conv->pixels + (size_t) i * conv->pitch,
+		   (size_t) w * 4);
+	}
+	SdlTkBorgToastSet(packed, w, h, ms);
+	ckfree(packed);
+    } else {
+	SdlTkBorgToastSet(conv->pixels, w, h, ms);
+    }
+    SDL_FreeSurface(conv);
+    return ret;
+}
