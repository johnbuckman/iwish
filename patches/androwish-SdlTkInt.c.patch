+#if defined(__APPLE__)
+#include <TargetConditionals.h>
+#if TARGET_OS_OSX || TARGET_OS_MACCATALYST
+#define SDLTK_MAC_POWERINFO 1
+#include <CoreFoundation/CoreFoundation.h>
+#include <IOKit/ps/IOPowerSources.h>
+#include <IOKit/ps/IOPSKeys.h>
+
+/*
+ * On a desktop Mac (undroidwish / iWish-on-Catalyst) SDL_GetPowerInfo
+ * misreports battery -- notably a Mac with no internal battery yields a bogus
+ * low percent, which drove the de1app into its low-battery screensaver.  Query
+ * the authoritative IOKit power-source API instead: returns the real battery
+ * percentage when on battery, or 100 when plugged into AC (or there is no
+ * battery at all, i.e. a desktop Mac).  Sets *onAC and *hasBattery.
+ */
+static int
+SdlTkMacPowerInfo(int *onAC, int *hasBattery)
+{
+    int pct = -1;
+    CFTypeRef blob;
+    CFStringRef ptype;
+    CFArrayRef list;
+
+    *onAC = 0;
+    *hasBattery = 0;
+    blob = IOPSCopyPowerSourcesInfo();
+    if (blob == NULL) {
+	*onAC = 1;		/* can't tell -> assume plugged in */
+	return 100;
+    }
+    ptype = IOPSGetProvidingPowerSourceType(blob);
+    if (ptype != NULL && CFEqual(ptype, CFSTR(kIOPSACPowerValue))) {
+	*onAC = 1;
+    }
+    list = IOPSCopyPowerSourcesList(blob);
+    if (list != NULL) {
+	CFIndex i, n = CFArrayGetCount(list);
+
+	for (i = 0; i < n; i++) {
+	    CFDictionaryRef d =
+		IOPSGetPowerSourceDescription(blob, CFArrayGetValueAtIndex(list, i));
+	    CFNumberRef ncur, nmax;
+	    CFStringRef st;
+	    int cur = 0, max = 0;
+
+	    if (d == NULL) {
+		continue;
+	    }
+	    ncur = (CFNumberRef) CFDictionaryGetValue(d, CFSTR(kIOPSCurrentCapacityKey));
+	    nmax = (CFNumberRef) CFDictionaryGetValue(d, CFSTR(kIOPSMaxCapacityKey));
+	    if (ncur != NULL) CFNumberGetValue(ncur, kCFNumberIntType, &cur);
+	    if (nmax != NULL) CFNumberGetValue(nmax, kCFNumberIntType, &max);
+	    if (max > 0) {
+		pct = (cur * 100) / max;
+		*hasBattery = 1;
+	    }
+	    st = (CFStringRef) CFDictionaryGetValue(d, CFSTR(kIOPSPowerSourceStateKey));
+	    if (st != NULL && CFEqual(st, CFSTR(kIOPSACPowerValue))) {
+		*onAC = 1;
+	    }
+	    break;		/* first battery is enough */
+	}
+	CFRelease(list);
+    }
+    CFRelease(blob);
+    if (!*hasBattery) {
+	*onAC = 1;		/* no battery -> desktop on wall power */
+	pct = 100;
+    }
+    return pct;
+}
