+#if TARGET_OS_MACCATALYST
+- (void)iwishScroll:(UIPanGestureRecognizer *)gr
+{
+    static int emittedY = 0, emittedX = 0;
+    if (gr.state == UIGestureRecognizerStateBegan) { emittedY = 0; emittedX = 0; return; }
+    if (gr.state != UIGestureRecognizerStateChanged) { return; }
+    CGPoint t = [gr translationInView:self];
+    const CGFloat TICK = 16.0;          /* px of scroll per wheel "click" */
+    int wantY = (int)(t.y / TICK), wantX = (int)(t.x / TICK);
+    /* fingers/scroll down (t.y>0) -> wheel.y>0 -> Button4 -> view earlier lines
+     * (matches macOS natural scrolling). */
+    while (emittedY < wantY) { SDL_SendMouseWheel(sdlwindow, 0, 0.0f,  1.0f, SDL_MOUSEWHEEL_NORMAL); emittedY++; }
+    while (emittedY > wantY) { SDL_SendMouseWheel(sdlwindow, 0, 0.0f, -1.0f, SDL_MOUSEWHEEL_NORMAL); emittedY--; }
+    while (emittedX < wantX) { SDL_SendMouseWheel(sdlwindow, 0,  1.0f, 0.0f, SDL_MOUSEWHEEL_NORMAL); emittedX++; }
+    while (emittedX > wantX) { SDL_SendMouseWheel(sdlwindow, 0, -1.0f, 0.0f, SDL_MOUSEWHEEL_NORMAL); emittedX--; }
+}
+#endif
