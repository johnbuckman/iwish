+/*
+ * Mac Catalyst event-loop support.
+ *
+ * On Catalyst, AppKit (via UIKitMacHelper) owns the process main run loop.
+ * SdlTkEventThread() normally runs an infinite blocking SDL_WaitEvent loop on
+ * the main thread; on Catalyst that never returns to -[NSApplication run], so
+ * the app is flagged "not responding" (spinning beachball). Instead we hand the
+ * main thread back to the run loop and process SDL events from a per-frame
+ * CADisplayLink callback -- the pattern SDL explicitly supports (it does not
+ * exit() when SDL_main returns).  The loop body below is a copy of the body in
+ * SdlTkEventThread(), using file-scope iteration state.
+ */
+static SDL_TimerID gTimerId = 0;
+static int gSkipRefresh = 0, gTimerSlow = 0;
+
+static void
+SdlTkEventLoopBody(SDL_Event sdl_event)
+{
+    XEvent event;
+    _XSQEvent *qevent;
+    int overrun;
+    (void) overrun; (void) qevent;
+	if (sdl_event.type == SDL_APP_DIDENTERBACKGROUND) {
+	    SDL_RemoveTimer(gTimerId);
+	    gTimerId = SDL_AddTimer(20 * 1000 / SDLTK_FRAMERATE, TimerCallback,
+				   (void *) &SdlTkX.time_count);
+	    gTimerSlow = 1;
+	}
+	memset(&event, 0, sizeof (event));
+	SdlTkLock(NULL);
+	if ((sdl_event.type == SDL_USEREVENT) &&
+	    (sdl_event.user.data1 == TimerCallback) &&
+	    (sdl_event.user.data2 != NULL)) {
+	    /* Disable timer messages. */
+	    SDL_AtomicSet(&timer_enabled, 0);
+	    if (!gSkipRefresh) {
+		SdlTkScreenRefresh();
+	    }
+	    overrun = (SdlTkX.time_count - sdl_event.user.code) > 0;
+	    gSkipRefresh = !gSkipRefresh && overrun;
+	    /* Mark event to be skipped in SdlTkTranslateEvent(). */
+	    sdl_event.type = SDL_USEREVENT + 0x1000;
+#if !defined(ANDROID) && defined(SDL_KEYBOARDEVENT_HAS_RATE_AND_DELAY)
+	    /* Key repeat handling for Wayland. */
+	    if (key_rpt_state && (SdlTkX.time_count - key_rpt_time >= 0)) {
+		if (key_event.key.rate) {
+		    key_rpt_time = SdlTkX.time_count + 1000/key_event.key.rate;
+		    if (key_rpt_state > 1) {
+			SDL_SendKeyboardText(txt_event.text.text);
+		    } else {
+			SDL_SendKeyboardKey(SDL_PRESSED,
+					    key_event.key.keysym.scancode,
+					    key_event.key.rate, 0);
+		    }
+		} else {
+		    key_rpt_state = 0;
+		}
+	    }
+#endif
+	}
+#if !defined(ANDROID) && defined(SDL_KEYBOARDEVENT_HAS_RATE_AND_DELAY)
+	/* Key repeat handling for Wayland. */
+	if ((sdl_event.type == SDL_KEYDOWN) && sdl_event.key.rate &&
+	    sdl_event.key.delay && !sdl_event.key.repeat) {
+	    key_rpt_state = 1;
+	    key_event = sdl_event;
+	    key_rpt_time = SdlTkX.time_count + key_event.key.delay;
+	    if (SDL_PeepEvents(&txt_event, 1, SDL_PEEKEVENT,
+			       SDL_TEXTINPUT, SDL_TEXTINPUT) == 1) {
+		key_rpt_state = 2;
+	    }
+	} else if (key_rpt_state && (sdl_event.type == SDL_KEYUP) &&
+		   sdl_event.key.rate && sdl_event.key.delay &&
+		   !sdl_event.key.repeat) {
+	    key_rpt_state = 0;
+	}
+#endif
+	if (sdl_event.type == SDL_USEREVENT) {
+	    /*
+	     * Remote procedure call handling.
+	     */
+	    int markDone = 0;
+
+	    if ((sdl_event.user.data1 == HandlePanZoom) &&
+		(sdl_event.user.data2 != NULL)) {
+		HandlePanZoom((struct PanZoomRequest *) sdl_event.user.data2);
+		markDone = 1;
+	    } else if ((sdl_event.user.data1 == HandleRootSize) &&
+		       (sdl_event.user.data2 != NULL)) {
+		HandleRootSize((struct RootSizeRequest *)
+			       sdl_event.user.data2);
+		markDone = 1;
+#ifndef ANDROID
+	    } else if ((sdl_event.user.data1 == HandleWindowSize) &&
+		       (sdl_event.user.data2 != NULL)) {
+		HandleWindowSize((struct RootSizeRequest *)
+			       sdl_event.user.data2);
+		markDone = 1;
+	    } else if ((sdl_event.user.data1 == HandleWindowFlags) &&
+		       (sdl_event.user.data2 != NULL)) {
+		HandleWindowFlags((struct WindowFlagsRequest *)
+				  sdl_event.user.data2);
+		markDone = 1;
+#endif
+#if defined(__APPLE__) || defined(_WIN32)
+	    } else if ((sdl_event.user.data1 == HandleWindowTitle) &&
+		       (sdl_event.user.data2 != NULL)) {
+		HandleWindowTitle((struct WindowTitleRequest *)
+				  sdl_event.user.data2);
+		markDone = 1;
+	    } else if ((sdl_event.user.data1 == HandleTextInput) &&
+		       (sdl_event.user.data2 != NULL)) {
+		HandleTextInput((struct TextInputRequest *)
+				sdl_event.user.data2);
+		markDone = 1;
+#endif
+	    } else if ((sdl_event.user.data1 == HandleWarpPointer) &&
+		       (sdl_event.user.data2 != NULL)) {
+		HandleWarpPointer((struct WarpPointerRequest *)
+				  sdl_event.user.data2);
+		markDone = 1;
+	    } else if ((sdl_event.user.data1 == HandleShowPointer) &&
+		       (sdl_event.user.data2 != NULL)) {
+		HandleShowPointer((struct WarpPointerRequest *)
+				  sdl_event.user.data2);
+		markDone = 1;
+	    }
+	    if (markDone) {
+		/* Mark event to be skipped in SdlTkTranslateEvent(). */
+		sdl_event.type = SDL_USEREVENT + 0x1000;
+	    }
+	}
+	if (SdlTkTranslateEvent(&sdl_event, &event, SdlTkX.time_count)) {
+	    SdlTkQueueEvent(&event);
+	}
+	SdlTkUnlock(NULL);
+	if (gTimerSlow && (!SdlTkX.in_background ||
+			  sdl_event.type == SDL_APP_WILLENTERFOREGROUND)) {
+	    SDL_RemoveTimer(gTimerId);
+	    gTimerId = SDL_AddTimer(1000 / SDLTK_FRAMERATE, TimerCallback,
+				   (void *) &SdlTkX.time_count);
+	    gTimerSlow = 0;
+	}
+	/* Remove left over events from SdlTkX.display. */
+	Tcl_MutexLock((Tcl_Mutex *) &SdlTkX.display->qlock);
+	qevent = SdlTkX.display->head;
+	while (qevent != NULL) {
+	    _XSQEvent *next = qevent->next;
+
+	    EVLOG("RemoveEvent %d %p", qevent->event.xany.type,
+		  (void *) qevent->event.xany.window);
+	    qevent->next = SdlTkX.display->qfree;
+	    SdlTkX.display->qfree = qevent;
+	    qevent = next;
+	}
+	SdlTkX.display->head = SdlTkX.display->tail = NULL;
+	SdlTkX.display->qlen = 0;
+	Tcl_MutexUnlock((Tcl_Mutex *) &SdlTkX.display->qlock);
+}
+
+static void SDLCALL
+SdlTkCatalystTick(void *clientData)
+{
+    SDL_Event sdl_event;
+
+    /* NB: we deliberately do NOT call SDL_StartTextInput here. With the GC
+     * keyboard disabled, SDL's pressesBegan delivers every key directly as a
+     * scancode (SdlTk derives the character from the keysym). Activating text
+     * input additionally routes presses through the hidden UITextField, which
+     * on Catalyst injects a spurious Return after a Space. */
+    SDL_AtomicSet(&timer_enabled, !SdlTkX.in_background);
+    while (SDL_PollEvent(&sdl_event)) {
+        if ((sdl_event.type == SDL_USEREVENT) &&
+            (sdl_event.user.data1 == Tcl_Exit)) {
+            exit(0);
+        }
+        if (SdlTkX.sdlscreen == NULL) {
+            exit(0);
+        }
+        SdlTkEventLoopBody(sdl_event);
+    }
+}
+#endif /* TARGET_OS_MACCATALYST */
